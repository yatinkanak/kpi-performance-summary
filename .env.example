# Copy to .env and adjust as needed.

# --- Postgres (used by docker-compose to provision the DB) ---
POSTGRES_USER=kps
POSTGRES_PASSWORD=kps
POSTGRES_DB=kps

# --- Application (KPS_ prefix is read by kpi_perf_summary_core.config.Settings) ---
# Set KPS_ENVIRONMENT=production to enable production guards (the dev token below is then rejected).
KPS_ENVIRONMENT=development
# Local (non-Docker) runs use this URL. Under docker-compose it is overridden per service
# (the api/mcp `environment:` blocks point at the `db` host), so keep this on `localhost`.
KPS_DATABASE_URL=postgresql+asyncpg://kps:kps@localhost:5432/kps
# Connection pool tuning (override per environment; defaults shown).
KPS_DB_POOL_SIZE=10
KPS_DB_MAX_OVERFLOW=20
KPS_DB_POOL_TIMEOUT=30
KPS_DB_POOL_RECYCLE=1800
KPS_DB_POOL_PRE_PING=true
KPS_PUBLISH_TOKEN=dev-publish-token
KPS_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
KPS_LOG_LEVEL=INFO

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000
